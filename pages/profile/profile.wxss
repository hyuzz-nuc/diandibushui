.container {
  background-color: #F0F8FF;
  min-height: 100vh;
  /* 顶部安全距离：通过 WXML 内联 style 动态设置 */
  padding-left: 20rpx;
  padding-right: 20rpx;
  padding-bottom: 20rpx;
}

.user-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 40rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.avatar-wrapper {
  padding: 0;
  width: 188rpx;
  height: 188rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  background-color: transparent;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 0;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 168rpx;
  height: 168rpx;
}

.avatar.placeholder {
  width: 168rpx;
  height: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(79, 195, 247, 0.12);
  border-radius: 50%;
}

.avatar-img {
  width: 168rpx;
  height: 168rpx;
  border-radius: 50%;
}

.avatar-ring {
  width: 188rpx;
  height: 188rpx;
  border-radius: 50%;
  padding: 10rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(79, 195, 247, 0.9), rgba(0, 176, 255, 0.9));
  box-shadow: 0 10rpx 26rpx rgba(0, 176, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 头像框样式 */
.avatar-frame {
  position: relative;
  padding: 8rpx;
  border-radius: 50%;
}

.avatar-frame.frame-orange {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
  box-shadow: 0 0 20rpx rgba(255, 152, 0, 0.5);
}

.avatar-frame.frame-green {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
  box-shadow: 0 0 20rpx rgba(76, 175, 80, 0.5);
}

.avatar-frame.frame-purple {
  background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%);
  box-shadow: 0 0 20rpx rgba(156, 39, 176, 0.5);
}

.avatar-frame.frame-gold {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 0 30rpx rgba(255, 215, 0, 0.6);
}

.avatar-frame.frame-diamond {
  background: linear-gradient(135deg, #B9F2FF 0%, #00BFFF 50%, #1E90FF 100%);
  box-shadow: 0 0 30rpx rgba(0, 191, 255, 0.6);
}

.avatar-frame.frame-legend {
  background: linear-gradient(135deg, #FF6B6B 0%, #FFD93D 25%, #6BCB77 50%, #4D96FF 75%, #9B59B6 100%);
  box-shadow: 0 0 40rpx rgba(255, 107, 107, 0.5);
  animation: rainbow-glow 3s ease-in-out infinite;
}

@keyframes rainbow-glow {
  0%, 100% { box-shadow: 0 0 40rpx rgba(255, 107, 107, 0.6); }
  25% { box-shadow: 0 0 40rpx rgba(255, 217, 61, 0.6); }
  50% { box-shadow: 0 0 40rpx rgba(107, 203, 119, 0.6); }
  75% { box-shadow: 0 0 40rpx rgba(77, 150, 255, 0.6); }
}

/* 用户称号 */
.user-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #00B0FF;
  margin-bottom: 12rpx;
}

/* 用户统计（金币+装扮） */
.user-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 176, 255, 0.1);
  width: 100%;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 24rpx;
}

.stat-icon {
  font-size: 28rpx;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF9800;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.08);
}

/* 登录按钮样式 */
.login-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%);
  border-radius: 40rpx;
  margin-bottom: 20rpx;
}

.login-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

/* 登录弹窗样式 */
.login-popup {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 40rpx;
}

.login-avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin-bottom: 32rpx;
}

.login-avatar-btn::after {
  border: none;
}

.login-avatar-wrapper {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx dashed #B3E5FC;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(79, 195, 247, 0.08);
}

.login-avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.login-avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-avatar-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.login-nickname-wrapper {
  width: 100%;
  margin-bottom: 32rpx;
}

.login-nickname-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

.login-popup-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 24rpx;
  text-align: center;
}

.invite-popup {
  padding: 32rpx;
}

.invite-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

.invite-tip {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.nickname-input {
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  width: 300rpx;
}

.title-badge {
  background-color: #FFF9C4;
  color: #FBC02D;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 10rpx;
}

.menu-list {
  margin-bottom: 40rpx;
}

.guide-cell {
  display: block;
}

/* ========== Dialog 按钮样式 ========== */
.van-dialog__footer {
  display: flex !important;
  justify-content: space-between !important;
  gap: 0 !important;
  padding: 0 !important;
}

.van-dialog__button {
  flex: 1 !important;
  width: 50% !important;
  height: 88rpx !important;
  font-size: 32rpx !important;
  border-radius: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.van-dialog__button--default,
.van-dialog__button--primary {
  width: 100% !important;
  height: 100% !important;
  border-radius: 0 !important;
  text-align: center !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.van-dialog__confirm {
  border-left: 1rpx solid #eee !important;
}

.save-btn-container {
  padding: 0 20rpx;
}
