<view class="container" style="padding-top: {{safeAreaTop}}px;">
  <view class="user-card">
    <!-- 未登录状态 -->
    <block wx:if="{{ !hasUserInfo }}">
      <view class="avatar-ring" bind:tap="onTapLogin">
        <view class="avatar placeholder">
          <van-icon name="user-circle-o" size="64px" color="#B3E5FC" />
        </view>
      </view>
      <view class="login-btn" bind:tap="onTapLogin">
        <text class="login-text">点击登录</text>
      </view>
      <view class="title-badge" wx:if="{{ userInfo.current_title }}" bind:tap="onViewPoster">
        <van-icon name="medal-o" /> {{ userInfo.current_title }} <van-icon name="arrow" size="12px" style="margin-left: 4px;" />
      </view>
    </block>

    <!-- 已登录状态 -->
    <block wx:else>
      <button class="avatar-wrapper" bind:tap="onPickAvatar">
        <view class="avatar-frame frame-{{ currentFrame }}">
          <view class="avatar-ring">
            <image class="avatar-img" mode="aspectFill" src="{{ userInfo.avatarUrl }}" />
          </view>
        </view>
      </button>
      <view class="user-title">{{ userInfo.title || userInfo.current_title || '饮水小白' }}</view>
      <view class="nickname-wrapper">
        <input class="nickname-input" placeholder="点击输入昵称" value="{{ userInfo.nickName }}" bind:change="onInputChange" />
        <van-icon name="edit" size="16px" color="#999" />
      </view>
    </block>
  </view>

  <!-- 金币和装扮 -->
  <view class="coins-card" wx:if="{{ hasUserInfo }}">
    <view class="coins-info">
      <text class="coins-icon">💰</text>
      <text class="coins-num">{{ coins }}</text>
      <text class="coins-label">金币</text>
    </view>
    <view class="decorations-info" bind:tap="goToDecorations">
      <text class="decorations-icon">🎨</text>
      <text class="decorations-text">我的装扮</text>
      <van-icon name="arrow" size="14px" color="#999" />
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <van-cell-group inset>
      <van-cell title="我的好友" icon="friends-o" is-link bind:click="goToSocial" />
      <view class="guide-cell" bindtap="restartGuide">
        <van-cell title="重新进入引导" icon="replay" is-link />
      </view>
      <van-cell title="用户反馈" icon="edit" is-link bind:click="openFeedback" />
      <van-cell title="关于我们" icon="info-o" is-link bind:click="showAbout" />
    </van-cell-group>
  </view>

  <!-- 保存按钮 (已登录状态显示) -->
  <view class="save-btn-container" wx:if="{{ hasUserInfo }}">
    <van-button type="primary" block round bind:click="saveUserInfo">同步个人信息</van-button>
  </view>

  <!-- 登录弹窗 -->
  <van-popup show="{{ showLoginPopup }}" position="bottom" round bind:close="onCloseLoginPopup">
    <view class="login-popup">
      <view class="login-popup-title">登录账号</view>

      <!-- 头像选择 -->
      <button class="login-avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseLoginAvatar">
        <view class="login-avatar-wrapper">
          <image wx:if="{{ loginAvatarUrl }}" class="login-avatar-img" src="{{ loginAvatarUrl }}" />
          <view wx:else class="login-avatar-placeholder">
            <van-icon name="user-circle-o" size="48px" color="#B3E5FC" />
          </view>
        </view>
        <text class="login-avatar-tip">点击选择头像</text>
      </button>

      <!-- 昵称输入 -->
      <view class="login-nickname-wrapper">
        <input
          class="login-nickname-input"
          type="nickname"
          placeholder="请输入昵称"
          value="{{ loginNickName }}"
          bind:change="onLoginNickNameChange"
        />
      </view>

      <!-- 登录按钮 -->
      <van-button type="primary" block round bind:click="onConfirmLogin">确认登录</van-button>
      <view class="login-popup-tip">登录后可同步数据，享受完整功能</view>
    </view>
  </van-popup>

  <!-- 邀请好友弹窗 -->
  <van-popup show="{{ showInvitePopup }}" position="bottom" round bind:close="onCloseInvite">
    <view class="invite-popup">
      <view class="invite-title">邀请好友成为喝水搭子</view>
      <van-button type="info" block round open-type="share">一键分享邀请</van-button>
      <view class="invite-tip">好友打开链接后会弹窗确认绑定</view>
    </view>
  </van-popup>

  <!-- Dialog 组件 -->
  <van-dialog id="van-dialog" />
</view>
