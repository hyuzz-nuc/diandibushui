<view class="container">
  <view class="header">
    <view class="header-left">
      <view class="notification-bell" bind:tap="toggleNotificationPanel">
        <van-icon name="bell" size="24" color="{{ hasUnreadNotice ? '#ff6b6b' : '#999' }}" />
        <view class="notification-dot" wx:if="{{ hasUnreadNotice }}"></view>
      </view>
    </view>
    <text class="greeting">Hi, 记得喝水哦 💧</text>
  </view>
  
  <!-- 通知中心弹窗 -->
  <van-popup
    show="{{ showNotificationPanel }}"
    position="top"
    round
    bind:close="toggleNotificationPanel"
    z-index="3000"
    custom-style="border-radius: 0 0 16px 16px; padding-top: calc(80rpx + env(safe-area-inset-top));"
  >
    <view class="notification-panel">
      <view class="panel-header">
        <text class="panel-title">消息中心</text>
        <view class="clear-all" wx:if="{{ notices.length > 0 }}" bind:tap="clearAllNotices">清空</view>
      </view>
      <view class="notice-list">
        <view class="notice-item" wx:if="{{ notices.length === 0 }}">
          <view class="notice-empty">暂无消息</view>
        </view>
        <view class="notice-item" wx:for="{{ notices }}" wx:key="id" bind:tap="onNoticeTap" data-item="{{ item }}">
          <view class="notice-icon {{ item.type }}">
            <van-icon name="{{ item.icon }}" size="20" color="#fff" />
          </view>
          <view class="notice-content">
            <view class="notice-title">{{ item.title }}</view>
            <view class="notice-desc">{{ item.desc }}</view>
            <view class="notice-time">{{ item.time }}</view>
          </view>
          <view class="notice-dot" wx:if="{{ !item.read }}"></view>
        </view>
      </view>
    </view>
  </van-popup>

  <!-- 底部打卡天数提示（可点击预览海报） -->
  <view class="bottom-bar">
    <view class="bottom-streak-bar" bind:tap="showPosterPreview">
      <text class="bottom-streak-text" wx:if="{{ consecutiveDays == 0 }}">💪 开始打卡，连续 7 天解锁惊喜海报</text>
      <text class="bottom-streak-text" wx:elif="{{ consecutiveDays > 0 && consecutiveDays < 7 }}">🔥 已连续打卡 {{ consecutiveDays }} 天，再坚持 {{ 7 - consecutiveDays }} 天解锁惊喜海报</text>
      <text class="bottom-streak-text" wx:else>🎉 已连续打卡 {{ consecutiveDays }} 天，点击查看惊喜海报</text>
    </view>
    <view class="reminder-entry" bind:tap="goToReminder">
      <van-icon name="bell" size="20" color="#00B0FF" />
    </view>
  </view>

  <!-- 海报预览弹窗 -->
  <van-popup
    show="{{ showPosterPopup }}"
    position="bottom"
    round
    custom-style="height: 92vh; background: #f5f7fa;"
    bind:close="closePosterPreview"
  >
    <view class="poster-popup">
      <!-- 关闭按钮 -->
      <view class="poster-close" bind:tap="closePosterPreview">
        <text class="close-icon">✕</text>
      </view>

      <!-- 全屏海报内容 -->
      <swiper
        class="poster-swiper"
        current="{{ currentPosterIndex }}"
        bindchange="onPosterSwiperChange"
        indicator-dots="{{ false }}"
      >
        <swiper-item wx:for="{{ posterList }}" wx:key="id">
          <view class="poster-fullscreen poster-{{ item.id }}" style="background: {{ item.bgColor }};">

            <!-- 装饰元素 -->
            <view class="poster-decor">
              <!-- 海报1：星星 -->
              <view class="stars" wx:if="{{ item.id === 1 }}">
                <text class="star s1">✨</text>
                <text class="star s2">⭐</text>
                <text class="star s3">✨</text>
                <text class="star s4">⭐</text>
              </view>
              <!-- 海报2：波浪 -->
              <view class="waves" wx:if="{{ item.id === 2 }}">
                <view class="wave wave1"></view>
                <view class="wave wave2"></view>
              </view>
              <!-- 海报3：水滴 -->
              <view class="drops" wx:if="{{ item.id === 3 }}">
                <text class="drop d1">💧</text>
                <text class="drop d2">💧</text>
                <text class="drop d3">💧</text>
                <text class="drop d4">💧</text>
              </view>
              <!-- 海报4：星光 -->
              <view class="sparkles" wx:if="{{ item.id === 4 }}">
                <text class="sparkle sp1">✨</text>
                <text class="sparkle sp2">⭐</text>
                <text class="sparkle sp3">✨</text>
                <text class="sparkle sp4">⭐</text>
                <text class="sparkle sp5">✨</text>
              </view>
            </view>

            <!-- 海报卡片 -->
            <view class="poster-card-wrapper {{ item.id === 4 ? 'golden-border' : '' }}">
              <view class="poster-content">
                <!-- Emoji -->
                <view class="poster-emoji-wrap">
                  <text class="poster-emoji">{{ item.emoji }}</text>
                  <text class="emoji-sparkle" wx:if="{{ item.id >= 3 }}">✨</text>
                </view>

                <!-- 称号 -->
                <text class="poster-title">{{ item.name }}</text>

                <!-- 分割线 -->
                <view class="poster-divider"></view>

                <!-- 祝贺语 -->
                <text class="poster-desc">{{ item.fullDesc }}</text>

                <!-- 打卡天数徽章 -->
                <view class="poster-badge">
                  <text class="badge-icon">{{ item.emoji }}</text>
                  <text class="badge-text">{{ item.unlockType === 'total' ? '累计打卡' : '连续打卡' }} {{ item.unlockDays }} 天</text>
                </view>

                <!-- 小程序码 -->
                <view class="poster-qrcode" wx:if="{{ (item.unlockType === 'total' ? totalDays : consecutiveDays) >= item.unlockDays }}">
                  <view class="qrcode-wrap">
                    <image wx:if="{{ qrCodeUrl }}" class="qrcode-img" src="{{ qrCodeUrl }}" mode="aspectFit" />
                    <view wx:else class="qrcode-placeholder">
                      <text>点击分享好友加载</text>
                    </view>
                  </view>
                  <text class="qrcode-text">长按识别小程序码</text>
                </view>

                <!-- 品牌信息 -->
                <view class="poster-brand">
                  <text class="brand-name">💧 点滴补水</text>
                  <text class="brand-slogan">每一滴水，都是对身体的宠爱</text>
                </view>
              </view>
            </view>

            <!-- 锁定遮罩（未解锁时显示） -->
            <view class="poster-lock-overlay" wx:if="{{ (item.unlockType === 'total' ? totalDays : consecutiveDays) < item.unlockDays }}">
              <view class="lock-content">
                <text class="lock-emoji">🔒</text>
                <text class="lock-title">{{ item.name }}</text>
                <text class="lock-condition">{{ item.unlockType === 'total' ? '累计打卡' : '连续打卡' }} {{ item.unlockDays }} 天解锁</text>
                <view class="lock-progress-bar">
                  <view class="lock-progress-fill" style="width: {{ (item.unlockType === 'total' ? totalDays : consecutiveDays) / item.unlockDays * 100 }}%;"></view>
                </view>
                <text class="lock-progress-text">{{ item.unlockType === 'total' ? totalDays : consecutiveDays }}/{{ item.unlockDays }}</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>

      <!-- 页码指示 -->
      <view class="poster-pagination">
        <view class="page-dots">
          <view class="dot {{ currentPosterIndex === index ? 'active' : '' }}" wx:for="{{ posterList }}" wx:key="id"></view>
        </view>
      </view>

      <!-- 底部按钮 -->
      <view class="poster-footer">
        <view class="action-btn primary" bind:tap="savePosterToAlbum">
          <text class="btn-icon">📷</text>
          <text class="btn-text">保存海报</text>
        </view>
        <view class="action-btn secondary" bind:tap="sharePoster">
          <text class="btn-icon">📤</text>
          <text class="btn-text">分享好友</text>
        </view>
      </view>
    </view>
  </van-popup>

  <!-- 进度圆环 -->
  <view class="progress-container" wx:if="{{ !showConfirmPopup && !showCupGuide && !showCustomDialog && !isSystemDialogShowing && !showRecommendDialog && !showWelcomeDialog && !showSocialGuideDialog && !showFinalDialog && !showNotificationPanel && !showPosterPopup }}">
    <van-circle 
      value="{{ percent }}" 
      color="{{ guideStep > 0 ? '#666666' : '#00B0FF' }}"
      layer-color="{{ guideStep > 0 ? 'rgba(100, 100, 100, 0.2)' : 'rgba(238, 238, 238, 0.3)' }}"
      stroke-width="10"
      size="220"
      text=""
      style="z-index: 0;"
    >
      <view class="circle-text">
        <text class="water-num">{{ currentWater }}</text>
        <text class="water-unit">ml</text>
        <view class="goal-wrapper" bind:tap="showRecommendDialog">
          <text class="goal-text">目标 {{ dailyGoal }}</text>
          <van-icon name="edit" size="12px" color="#999" custom-style="margin-left: 4px; vertical-align: middle;" />
        </view>
      </view>
    </van-circle>
  </view>
  
  <!-- 占位符，保持布局高度，防止闪烁 -->
  <view class="progress-placeholder" wx:if="{{ showConfirmPopup || showCupGuide || showCustomDialog }}">
      <view class="circle-text">
        <text class="water-num">{{ currentWater }}</text>
        <text class="water-unit">ml</text>
        <view class="goal-wrapper">
          <text class="goal-text">目标 {{ dailyGoal }}</text>
          <van-icon name="edit" size="12px" color="#999" custom-style="margin-left: 4px; vertical-align: middle;" />
        </view>
      </view>
  </view>

  <view class="controls">
    <view class="btn-group">
      <van-button round type="info" size="normal" custom-class="water-btn {{ guideStep === 4 ? 'guide-highlight-target' : '' }}" data-amount="200" bind:click="addWater">
        <view class="btn-content">
          <van-icon name="fire-o" /> +200
        </view>
      </van-button>
      <van-button round type="info" size="normal" custom-class="water-btn" data-amount="300" bind:click="addWater">
        <view class="btn-content">
          <van-icon name="cup-o" /> +300
        </view>
      </van-button>
      <van-button round type="info" size="normal" custom-class="water-btn" data-amount="500" bind:click="addWater">
         <view class="btn-content">
          <van-icon name="star-o" /> +500
        </view>
      </van-button>
    </view>
    
    <view class="extra-controls">
      <view class="extra-btn" bind:tap="onCustomWater">
        <van-icon name="edit" /> 自定义
      </view>
      <view class="divider">|</view>
      <view class="extra-btn" bind:tap="toggleCupGuide">
        <van-icon name="question-o" /> 常见杯型
      </view>
    </view>

    <view class="custom-input"></view>
  </view>

  <!-- Vant Dialog 专用节点（供 Dialog API 使用） -->
  <van-dialog id="van-dialog" />

  <!-- 目标设置弹窗（智能推荐/自定义） -->
  <van-popup
    show="{{ showRecommendDialog }}"
    position="bottom"
    round
    bind:close="onCloseDialog"
    z-index="10000"
    custom-style="border-radius: 16px 16px 0 0; max-height: 80vh;"
    safe-area-inset-bottom="{{ true }}"
    adjusted="{{ true }}"
  >
    <scroll-view scroll-y style="max-height: 80vh;">
      <view class="guide-popup-content" style="padding: 20rpx;">
        <!-- 步骤 0：选择模式 -->
        <view wx:if="{{ goalGuideSubStep === 0 }}">
          <view class="goal-mode-card" bind:tap="selectGoalMode" data-mode="smart">
            <view class="goal-mode-icon">🤖</view>
            <view class="goal-mode-info">
              <view class="goal-mode-title">智能生成</view>
              <view class="goal-mode-desc">根据体重/职业科学计算</view>
            </view>
          </view>
          
          <view class="goal-mode-card" data-mode="custom" bind:tap="selectGoalMode">
            <view class="goal-mode-icon">📝</view>
            <view class="goal-mode-info">
              <view class="goal-mode-title">手动设置</view>
              <view class="goal-mode-desc">自己输入每日目标</view>
            </view>
          </view>
        </view>

        <!-- 步骤 1：智能 - 输入体重 -->
        <view class="goal-step-container" wx:if="{{ goalGuideSubStep === 1 }}">
      <view class="step-title">为了更准确的推荐，请输入您的体重</view>
      <view class="input-highlight-wrapper">
        <van-field
          value="{{ weight }}"
          type="digit"
          label="体重 (kg)"
          placeholder="例如 60"
          border="{{ false }}"
          bind:change="onWeightChange"
          input-align="center"
          adjust-position="{{ true }}"
          clear="{{ false }}"
          custom-style="background: #F5F7FA; border-radius: 12px; font-size: 32rpx; padding: 20rpx;"
        />
      </view>
      <view class="step-actions single-btn">
        <van-button type="info" custom-class="step-btn" bind:click="nextSmartStep">下一步</van-button>
      </view>
    </view>

    <!-- 步骤 2：智能 - 选择职业 -->
    <view class="goal-step-container" wx:if="{{ goalGuideSubStep === 2 }}">
      <view class="step-title">您的日常活动强度是？</view>
      <view class="occupation-group-vertical">
        <view 
          class="occupation-item-large {{ occupation === 'office' ? 'active' : '' }}" 
          bind:tap="onOccupationChange" 
          data-type="office"
        >
          <text>🖥️ 脑力/办公</text>
        </view>
        <view 
          class="occupation-item-large {{ occupation === 'light' ? 'active' : '' }}" 
          bind:tap="onOccupationChange" 
          data-type="light"
        >
          <text>🚶 轻体力活动</text>
        </view>
        <view 
          class="occupation-item-large {{ occupation === 'heavy' ? 'active' : '' }}" 
          bind:tap="onOccupationChange" 
          data-type="heavy"
        >
          <text>🏋️ 重体力/运动</text>
        </view>
      </view>
      <view class="step-actions single-btn">
        <van-button type="info" custom-class="step-btn" bind:click="nextSmartStep">下一步</van-button>
      </view>
    </view>

    <!-- 步骤 3：智能 - 结果确认 -->
    <view class="goal-step-container" wx:if="{{ goalGuideSubStep === 3 }}">
      <view class="result-circle">
        <view class="result-val">{{ recommendGoal }}<text class="unit">ml</text></view>
        <view class="result-label">每日推荐目标</view>
      </view>
      <view class="step-actions center">
        <view class="confirm-wrapper">
          <van-button type="primary" custom-class="step-btn" bind:click="confirmRecommend">
            确认目标
          </van-button>
        </view>
        <view class="re-calc" bind:tap="prevSmartStep">重新计算</view>
      </view>
    </view>

    <!-- 步骤 4：自定义 - 输入数值 -->
    <view class="goal-step-container" wx:if="{{ goalGuideSubStep === 4 }}">
      <view class="step-title">请输入您的每日饮水目标</view>
      <view class="input-highlight-wrapper">
        <van-field
          value="{{ customGoalInput }}"
          type="digit"
          label="目标 (ml)"
          placeholder="请输入数值"
          border="{{ false }}"
          bind:change="onCustomGoalInputChange"
          input-align="center"
          custom-style="background: #F5F7FA; border-radius: 12px; font-size: 32rpx; padding: 20rpx;"
        />
      </view>
      <view class="step-actions single-btn">
        <van-button type="primary" custom-class="step-btn" bind:click="confirmRecommend">确认目标</van-button>
      </view>
    </view>
    </view>
    </scroll-view>
  </van-popup>

  <!-- 自定义喝水量弹窗（改为底部弹出） -->
  <van-popup
    show="{{ showCustomDialog }}"
    position="bottom"
    round
    bind:close="onCloseCustom"
    z-index="9999"
    custom-style="border-radius: 16px 16px 0 0;"
  >
    <view style="padding: 40rpx 30rpx calc(120rpx + env(safe-area-inset-bottom));">
      <view style="font-size: 32rpx; font-weight: bold; color: #333; margin-bottom: 30rpx; text-align: center;">自定义喝水量</view>
      <van-field
        value="{{ customAmount }}"
        type="digit"
        label="水量 (ml)"
        placeholder="请输入数值"
        border="{{ true }}"
        bind:change="onCustomAmountChange"
        input-align="center"
        focus="{{ showCustomDialog }}"
        adjust-position="{{ true }}"
        clear="{{ false }}"
      />
      <view class="custom-actions">
        <van-button 
          size="normal" 
          type="default" 
          bind:click="onCloseCustom"
          custom-class="action-btn-cancel"
        >取消</van-button>
        <van-button 
          size="normal" 
          type="info" 
          bind:click="onConfirmCustom"
          custom-class="action-btn-confirm"
        >确认</van-button>
      </view>
    </view>
  </van-popup>

  <!-- 杯型参考弹窗 -->
  <van-popup
    show="{{ showCupGuide }}"
    position="bottom"
    round
    bind:close="toggleCupGuide"
    custom-style="height: 50%;"
    z-index="9999"
  >
    <view class="cup-guide-container">
      <view class="guide-title">常见杯型参考 (点击可直接记录)</view>
      <view class="cup-grid">
        <view class="cup-item" wx:for="{{ cupTypes }}" wx:key="name" bind:tap="onSelectCup" data-volume="{{ item.volume }}">
          <view class="cup-icon">{{ item.icon }}</view>
          <view class="cup-name">{{ item.name }}</view>
          <view class="cup-volume">{{ item.volume }}ml</view>
        </view>
      </view>
    </view>
  </van-popup>

  <!-- 底部喝水确认弹窗 -->
  <van-popup
    show="{{ showConfirmPopup }}"
    position="bottom"
    round
    bind:close="onCancelAdd"
    safe-area-inset-bottom="{{ false }}"
    z-index="9999"
  >
    <view class="confirm-popup-container">
      <view class="confirm-title">喝水确认</view>
      <view class="confirm-content">
        <view class="confirm-icon">💧</view>
        <view class="confirm-text">确定记录喝了 <text class="highlight">{{ pendingAmount }}ml</text> 水吗？</view>
      </view>
      <view class="confirm-actions">
        <view class="action-btn-wrapper">
          <van-button round block type="default" custom-class="cancel-btn" bind:click="onCancelAdd">点错了</van-button>
        </view>
        <view class="action-btn-wrapper">
          <van-button round block type="info" custom-class="confirm-btn" bind:click="onConfirmAdd">咕噜咕噜</van-button>
        </view>
      </view>
    </view>
  </van-popup>

  <!-- 新手引导欢迎弹窗（Step 1） -->
  <van-popup
    show="{{ showWelcomeDialog }}"
    position="bottom"
    round
    close-on-click-overlay="{{ false }}"
    bind:close="onCloseDialog"
    z-index="10000"
    custom-style="border-radius: 16px 16px 0 0;"
  >
    <view class="guide-popup-content">
      <view class="guide-icon">👋</view>
      <view class="guide-message">
        Hi～我是你的喝水小助手！忙碌的时候也别忘了养成喝水的好习惯哦～
      </view>
      <view class="guide-sub-message">只需简单几步，开启健康一天！</view>
      
      <view class="guide-action-area">
        <view class="guide-pointing-hand">👆</view>
        <van-button 
          type="primary" 
          round 
          color="#00B0FF"
          custom-class="guide-start-btn"
          bind:click="nextGuideStep"
        >
          开始引导
        </van-button>
      </view>
    </view>
  </van-popup>

  <!-- 新手引导遮罩层（Step 4） -->
  <view class="guide-overlay" wx:if="{{ guideStep === 4 }}" catch:touchmove="preventTouchMove">
    <view class="guide-mask-full"></view>
    
    <view class="guide-tip-container">
      <view class="guide-hand">👆</view>
      <view class="guide-text">点击上方的喝水按钮记录第一杯水</view>
      <view class="guide-sub-text">（温馨提示：引导期间记录的喝水数据不会实际保存）</view>
    </view>
  </view>

  <!-- 社交引导弹窗（Step 5） -->
  <van-popup
    show="{{ showSocialGuideDialog }}"
    position="bottom"
    round
    close-on-click-overlay="{{ false }}"
    bind:close="onCloseDialog"
    z-index="10000"
    custom-style="border-radius: 16px 16px 0 0;"
  >
    <view class="guide-popup-content">
      <view class="guide-icon">👯</view>
      <view class="guide-message">
        一个人太孤单，去 <strong>「社交」</strong> 页面找好友监督吧！
      </view>
      <view class="guide-sub-message">喝水打卡 PK 中，看看谁才是真正的「喝水王者」</view>
      
      <view style="margin-top: 40rpx; width: 80%; margin-left: auto; margin-right: auto;">
        <van-button 
          round 
          block 
          color="#00B0FF" 
          bind:click="nextGuideStep"
        >去社交页看看</van-button>
      </view>
    </view>
  </van-popup>

  <!-- 最终完成弹窗（引导结束后显示） -->
  <van-popup
    show="{{ showFinalDialog }}"
    position="bottom"
    round
    close-on-click-overlay="{{ false }}"
    z-index="10000"
  >
    <view style="padding: 20px; text-align: center; color: #666; font-size: 14px; line-height: 1.6;">
      <view>刚才的记录仅供演示，数据已为您重置。</view>
      <view>现在，开启您的正式补水之旅吧！</view>
    </view>
    <view style="margin-top: 20rpx; width: 80%; margin-left: auto; margin-right: auto; padding-bottom: 20px;">
      <van-button 
        round 
        block 
        color="#00B0FF" 
        bind:click="onConfirmFinalDialog"
      >开始补水</van-button>
    </view>
  </van-popup>

</view>

<!-- 隐藏的 Canvas 用于生成海报 -->
<canvas type="2d" id="posterCanvas" style="position: fixed; left: -9999px; top: -9999px;"></canvas>
