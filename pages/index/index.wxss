.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0;
  height: 80vh;
  box-sizing: border-box;
}

/* ===================================
   新手引导层级控制
   确保引导弹窗不被导航栏和圆环遮挡
   =================================== */

/* 导航栏默认层级 */
.weui-navigation-bar {
  z-index: 100 !important;
}

/* 引导遮罩层和弹窗最高优先级 */
.guide-modal,
.van-dialog,
.van-overlay,
.van-popup {
  z-index: 10000 !important;
}

/* 圆环进度条默认底层 */
.progress-container,
.progress-placeholder,
.water-ring,
.ring-decoration,
.circle-progress {
  z-index: 0 !important; /* 改为 0，确保最低 */
}

.header {
  position: relative;
  margin-top: 60rpx; /* 固定安全距离，适配刘海屏 */
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 20rpx;
}

.header-left {
  position: absolute;
  left: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
}

/* 打卡天数提示栏 */

.greeting {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

/* 底部打卡天数提示栏 */
.bottom-streak-bar {
  position: fixed;
  bottom: 210rpx; /* 往上移动 90rpx */
  left: 50%;
  transform: translateX(-50%);
  padding: 12rpx 40rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border-radius: 28rpx;
  border: 1rpx solid #FFD54F;
  box-shadow: 0 4rpx 12rpx rgba(255, 183, 77, 0.3);
  z-index: 100;
}

.bottom-streak-text {
  font-size: 24rpx;
  color: #E65100;
  font-weight: 600;
  white-space: nowrap;
}

.notification-dot {
}

/* ========== 通知中心面板 ========== */
.notification-panel {
  padding: calc(30rpx + env(safe-area-inset-top)) 20rpx 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.clear-all {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 16rpx;
}

.clear-all:active {
  color: #00B0FF;
}

.notice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notice-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  position: relative;
}

.notice-item:active {
  background: #f0f1f2;
}

.notice-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.notice-icon.invite {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.notice-icon.welfare {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.notice-icon.notice {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.notice-icon.system {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.notice-content {
  flex: 1;
  min-width: 0;
}

.notice-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.notice-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.notice-time {
  font-size: 20rpx;
  color: #999;
}

.notice-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ff6b6b;
  border-radius: 50%;
  flex-shrink: 0;
  margin-left: 10rpx;
}

.notice-empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding: 40rpx 0;
  width: 100%;
}

.progress-container {
  margin: 60rpx 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

.circle-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.progress-placeholder {
  margin: 60rpx 0;
  width: 220px; 
  height: 220px;
  border-radius: 50%;
  border: 10px solid rgba(238, 238, 238, 0.3);
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
}

.water-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #00B0FF;
}

.water-unit {
  font-size: 24rpx;
  color: #999;
  margin-top: -10rpx;
}

.goal-wrapper {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 10rpx;
}

.goal-wrapper:active {
  background-color: #f5f5f5;
}

.goal-text {
  font-size: 24rpx;
  color: #999;
}

.controls {
  width: 100%;
  padding: 0 40rpx;
  box-sizing: border-box;
}

.btn-group {
  display: flex;
  justify-content: space-around;
  width: 100%;
}

.water-btn {
  width: 180rpx !important;
  box-shadow: 0 4rpx 10rpx rgba(0, 176, 255, 0.3);
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

/* ========== 额外控制区 ========== */
.extra-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20px;
  gap: 15px;
}

.extra-btn {
  font-size: 14px;
  color: #666;
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 8px 12px;
  background: #f5f5f5;
  border-radius: 20px;
}

.extra-btn:active {
  background: #eeeeee;
}

.divider {
  color: #ddd;
}

/* ========== 杯型参考样式 ========== */
.cup-guide-container {
  padding: 40rpx 20rpx calc(250rpx + env(safe-area-inset-bottom)) 20rpx;
}

.guide-title {
  text-align: center;
  font-size: 16px;
  font-weight: bold;
  margin-bottom: 20px;
  color: #333;
}

.cup-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15px;
}

.cup-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15px 0;
  background: #f9f9f9;
  border-radius: 8px;
}

.cup-item:active {
  background: #f0f0f0;
}

.cup-icon {
  font-size: 32px;
  margin-bottom: 8px;
}

.cup-name {
  font-size: 13px;
  color: #333;
}

.cup-volume {
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

/* ========== 底部确认弹窗样式 ========== */
.confirm-popup-container {
  padding: 60rpx 40rpx calc(180rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 自定义弹窗按钮样式 */
.custom-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 40rpx;
  gap: 20rpx;
}

.action-btn-cancel {
  flex: 1;
  height: 88rpx !important;
  background: #f5f5f5 !important;
  border: none !important;
  border-radius: 44rpx !important;
  font-size: 32rpx !important;
  color: #999 !important;
}

.action-btn-confirm {
  flex: 1;
  height: 88rpx !important;
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%) !important;
  border: none !important;
  border-radius: 44rpx !important;
  font-size: 32rpx !important;
  color: #fff !important;
  box-shadow: 0 8rpx 24rpx rgba(0, 176, 255, 0.4) !important;
}

/* ========== 自定义 Dialog 样式 (打卡成功) ========== */
.celebrate-dialog .van-button {
  background: linear-gradient(135deg, #81D4FA 0%, #29B6F6 100%) !important;
  border: none !important;
  color: #ffffff !important;
  width: 70% !important;
  margin: 0 auto 30rpx !important;
  box-shadow: 0 4rpx 12rpx rgba(41, 182, 246, 0.3) !important;
  font-size: 32rpx !important;
  letter-spacing: 2rpx;
}

.celebrate-dialog .van-dialog__header {
  padding-top: 40rpx;
  font-weight: bold;
  font-size: 36rpx;
}

.confirm-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.confirm-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.confirm-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.confirm-text {
  font-size: 32rpx;
  color: #666;
}

.highlight {
  color: #00B0FF;
  font-weight: bold;
  font-size: 40rpx;
  margin: 0 8rpx;
}

.confirm-actions {
  display: flex;
  width: 100%;
  gap: 30rpx;
  justify-content: space-between;
}

.action-btn-wrapper {
  flex: 1;
  display: block; 
}

.action-btn-wrapper {
  flex: 1 !important;
  width: 0 !important;
  display: block !important;
}

.cancel-btn {
  width: 100% !important;
  background-color: #f5f5f5 !important;
  color: #999 !important;
  border: none !important;
  font-size: 32rpx !important;
  height: 88rpx !important;
  text-align: center !important;
  padding: 0 !important;
  border-radius: 44rpx !important;
}

.cancel-btn .van-button__text {
  display: block !important;
  width: 100% !important;
  text-align: center !important;
}

.confirm-btn {
  width: 100% !important;
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%) !important;
  border: none !important;
  font-size: 32rpx !important;
  height: 88rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(0, 176, 255, 0.4) !important;
  text-align: center !important;
  padding: 0 !important;
  border-radius: 44rpx !important;
}

.confirm-btn .van-button__text {
  display: block !important;
  width: 100% !important;
  text-align: center !important;
}

/* ========== Vant Dialog 按钮样式统一 ========== */
.van-dialog__footer {
  display: flex !important;
  justify-content: space-between !important;
  gap: 0 !important;
  padding: 0 !important;
}

.van-dialog__button {
  flex: 1 !important;
  width: 50% !important;
  height: 88rpx !important;
  font-size: 32rpx !important;
  border-radius: 0 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.van-dialog__button--default,
.van-dialog__button--primary {
  width: 100% !important;
  height: 100% !important;
  border-radius: 0 !important;
  text-align: center !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
}

.van-dialog__confirm {
  border-left: 1rpx solid #eee !important;
}

/* ========== 引导弹窗内部样式（底部弹出） ========== */
.guide-popup-content {
  padding: 40rpx 30rpx calc(120rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  max-height: 70vh;
  overflow-y: auto;
}

/* ========== 目标设置引导分步样式 ========== */
.goal-step-container {
  padding: 30rpx 20rpx;
  min-height: 400rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 模式卡片 */
.goal-mode-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin-bottom: 24rpx;
  background: #f8fcff;
  border: 2rpx solid #e1f3ff;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.3s;
  min-height: 140rpx; /* 固定最小高度 */
  box-sizing: border-box; /* 确保 padding 不影响高度 */
}

.goal-mode-card:active {
  background: #e6f7ff;
}

.goal-mode-icon {
  font-size: 60rpx;
  margin-right: 24rpx;
  flex-shrink: 0; /* 防止图标被压缩 */
  width: 60rpx; /* 固定图标宽度 */
  text-align: center;
}

.goal-mode-info {
  flex: 1; /* 内容区域占满剩余空间 */
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0; /* 防止内容溢出 */
}

.goal-mode-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.2;
}

.goal-mode-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.2;
}

/* 输入框高亮 */
.input-highlight-wrapper {
  position: relative;
  margin: 40rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 0 0 4rpx rgba(0, 176, 255, 0.2);
  animation: pulse-border 2s infinite;
}

@keyframes pulse-border {
  0% { box-shadow: 0 0 0 0 rgba(0, 176, 255, 0.4); }
  70% { box-shadow: 0 0 0 10px rgba(0, 176, 255, 0); }
  100% { box-shadow: 0 0 0 0 rgba(0, 176, 255, 0); }
}

.step-title {
  text-align: center;
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.step-actions {
  display: flex !important;
  justify-content: space-between !important;
  margin-top: 40rpx !important;
  padding: 0 20rpx !important;
  gap: 20rpx !important;
  width: 100% !important;
  box-sizing: border-box !important;
}

.step-actions.single-btn {
  justify-content: center !important;
  padding: 0 !important;
}

.step-actions .van-button {
  flex: 1 !important;
  min-width: 0 !important;
  text-align: center !important;
  padding: 0 !important;
  margin: 0 !important;
  box-sizing: border-box !important;
}

.step-actions.single-btn .van-button {
  width: 80% !important;
  flex: none !important;
}

.step-actions .van-button--normal {
  width: 100% !important;
}

.step-actions .van-button__text {
  display: block !important;
  width: 100% !important;
  text-align: center !important;
  line-height: normal !important;
}

/* ========== 引导步骤按钮专用样式 ========== */
.step-btn,
.step-btn.van-button,
.step-btn .van-button__inner,
.step-btn .van-button__text,
.step-actions .van-button {
  overflow: visible !important;
  text-overflow: clip !important;
  white-space: nowrap !important;
}

.step-btn,
.step-btn.van-button {
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 6rpx 16rpx rgba(0, 176, 255, 0.35) !important;
  border-radius: 12rpx !important;
  width: 80% !important;
  max-width: 500rpx !important;
  min-width: 300rpx !important;
  height: 88rpx !important;
  min-height: 88rpx !important;
  font-size: 32rpx !important;
  font-weight: 500 !important;
  letter-spacing: 4rpx !important;
  padding: 0 !important;
  margin: 40rpx auto 20rpx auto !important;
  display: inline-block !important;
  position: relative !important;
}

.step-btn .van-button__inner,
.step-btn.van-button .van-button__inner {
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  height: 88rpx !important;
  width: 100% !important;
  line-height: 88rpx !important;
}

.step-btn .van-button__text,
.step-btn.van-button .van-button__text {
  display: block !important;
  text-align: center !important;
  color: #ffffff !important;
  font-size: 32rpx !important;
  line-height: 88rpx !important;
  white-space: nowrap !important;
  padding: 0 !important;
  margin: 0 !important;
}

.step-actions.single-btn {
  display: flex !important;
  justify-content: center !important;
  width: 100% !important;
}

.step-actions.single-btn .van-button {
  width: auto !important;
  max-width: 500rpx !important;
  min-width: 300rpx !important;
  flex: none !important;
  margin: 0 auto !important;
}

.step-actions.center {
  display: flex !important;
  justify-content: center !important;
  flex-direction: column !important;
  align-items: center !important;
  width: 100% !important;
}

.step-actions.center .van-button {
  width: 80% !important;
  max-width: 500rpx !important;
  margin: 0 auto !important;
  display: block !important;
}

.step-actions.center .confirm-wrapper {
  width: 100% !important;
  display: flex !important;
  justify-content: center !important;
  position: relative !important;
}

/* 垂直职业选择 */
.occupation-group-vertical {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.occupation-item-large {
  padding: 32rpx 40rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  min-width: 400rpx;
  text-align: center;
}

.occupation-item-large.active {
  background: #e6f7ff;
  border-color: #00B0FF;
  color: #00B0FF;
  font-weight: bold;
}

/* 结果圆环 */
.result-circle {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  border: 10rpx solid #00B0FF;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin: 0 auto 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 176, 255, 0.2);
}

.result-val {
  font-size: 56rpx;
  font-weight: bold;
  color: #00B0FF;
}

.result-val .unit {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.confirm-wrapper {
  position: relative;
  width: 100%;
  margin-bottom: 20rpx;
}

.re-calc {
  font-size: 24rpx;
  color: #999;
  text-decoration: underline;
  padding: 10rpx;
}

/* ===================================
   新手引导统一样式（底部弹窗）
   =================================== */
.guide-popup-content {
  padding: 40rpx 30rpx calc(120rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.guide-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  animation: bounce-in 0.6s ease-out;
}

.guide-message {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.guide-sub-message {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.guide-action-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
  position: relative;
}

.guide-pointing-hand {
  font-size: 80rpx;
  margin-bottom: -160rpx;
  animation: point-down 1.5s infinite;
  z-index: 10;
}

.guide-start-btn {
  width: 80%;
  min-width: 300rpx;
  height: 88rpx;
  font-size: 32rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 176, 255, 0.35);
}

/* ========== 新手引导遮罩 ========== */
.guide-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 900;
  pointer-events: none; /* 让点击穿透遮罩层 */
}

.guide-mask-full {
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.85);
  pointer-events: auto; /* 遮罩背景可以阻挡点击 */
}

/* 高亮目标按钮 */
.guide-highlight-target {
  position: relative;
  z-index: 1000 !important; /* 必须高于遮罩层 900 */
  box-shadow: 0 0 0 10rpx rgba(255, 255, 255, 0.3), 0 0 50rpx rgba(255, 255, 255, 0.6) !important;
  animation: pulse-target 2s infinite;
  background-color: #00B0FF !important;
  color: #fff !important;
}

/* 强制覆盖 Vant 按钮内部样式 */
.guide-highlight-target .van-button__inner,
.guide-highlight-target .van-hairline--surround {
  background-color: #00B0FF !important;
  border-color: transparent !important;
}

.guide-highlight-target .van-button__text {
  color: #fff !important;
}

@keyframes pulse-target {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.guide-tip-container {
  position: absolute;
  bottom: 300rpx; /* 调整位置，避免遮挡 */
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 40rpx;
  animation: float-up 0.6s ease-out;
}

.guide-hand {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
  animation: point-down 1.5s infinite;
}

.guide-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.guide-sub-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

@keyframes point-down {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(20rpx); }
}

@keyframes float-up {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pulse-target {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.guide-tip-container {
  position: absolute;
  bottom: 300rpx;
  left: 0;
  right: 0;
  text-align: center;
  padding: 0 40rpx;
  animation: float-up 0.6s ease-out;
}

.guide-hand {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
  animation: point-down 1.5s infinite;
}

.guide-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.guide-sub-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

@keyframes point-down {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(20rpx); }
}

@keyframes float-up {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes bounce-in {
  0% {
    opacity: 0;
    transform: scale(0.3);
  }
  50% {
    transform: scale(1.05);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    opacity: 1;
    transform: scale(1);
  }
}
