<view class="container" style="padding-top: {{safeAreaTop}}px;">
  <!-- 自定义导航栏 -->
  <view class="custom-nav">
    <view class="nav-back" bind:tap="goBack">
      <van-icon name="arrow-left" size="20" color="#333" />
    </view>
    <text class="nav-title">🛒 商城</text>
    <view class="nav-coins">
      <text class="coins-icon">💰</text>
      <text class="coins-num">{{ coins }}</text>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="shop-tabs">
    <view class="tab-item {{ activeTab === 'ring' ? 'active' : '' }}" bind:tap="switchTab" data-tab="ring">
      <text class="tab-icon">⭕</text>
      <text class="tab-name">圆环</text>
    </view>
    <view class="tab-item {{ activeTab === 'button' ? 'active' : '' }}" bind:tap="switchTab" data-tab="button">
      <text class="tab-icon">🔘</text>
      <text class="tab-name">按钮</text>
    </view>
    <view class="tab-item {{ activeTab === 'effect' ? 'active' : '' }}" bind:tap="switchTab" data-tab="effect">
      <text class="tab-icon">✨</text>
      <text class="tab-name">特效</text>
    </view>
    <view class="tab-item {{ activeTab === 'frame' ? 'active' : '' }}" bind:tap="switchTab" data-tab="frame">
      <text class="tab-icon">🖼️</text>
      <text class="tab-name">头像框</text>
    </view>
  </view>

  <!-- 商品列表 -->
  <scroll-view scroll-y class="shop-scroll">
    <view class="shop-grid">
      <view class="shop-item {{ item.owned ? 'owned' : '' }} {{ item.locked ? 'locked' : '' }}"
            wx:for="{{ currentItems }}" wx:key="name"
            bind:tap="onItemTap" data-item="{{ item }}">
        <view class="item-preview {{ item.previewClass }}">
          <text class="preview-icon">{{ item.icon }}</text>
        </view>
        <view class="item-info">
          <text class="item-name">{{ item.name }}</text>
          <view class="item-price" wx:if="{{ item.price > 0 }}">
            <text class="price-icon">💰</text>
            <text class="price-num">{{ item.price }}</text>
          </view>
          <text class="item-free" wx:else>免费</text>
        </view>
        <view class="item-duration">30天</view>
        <view class="item-status">
          <text wx:if="{{ item.locked }}">🔒 Lv.{{ item.unlockLevel }}</text>
          <text wx:elif="{{ item.owned && item.expired }}">已过期</text>
          <text wx:elif="{{ item.owned }}">{{ item.remainDays }}天</text>
          <text wx:else>购买</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 购买确认弹窗 -->
  <van-popup
    show="{{ showBuyPopup }}"
    position="bottom"
    round
    bind:close="closeBuyPopup"
  >
    <view class="buy-popup">
      <view class="buy-title">确认购买</view>
      <view class="buy-item">
        <text class="buy-icon">{{ selectedItem.icon }}</text>
        <text class="buy-name">{{ selectedItem.name }}</text>
      </view>
      <view class="buy-info">
        <text>有效期：30天</text>
        <text>花费：💰 {{ selectedItem.price || 0 }}</text>
      </view>
      <view class="buy-actions">
        <view class="buy-btn cancel" bind:tap="closeBuyPopup">取消</view>
        <view class="buy-btn confirm" bind:tap="confirmBuy">确认购买</view>
      </view>
    </view>
  </van-popup>
</view>
