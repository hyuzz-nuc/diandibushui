.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #F5F5F5 30%);
  padding: 20rpx;
  padding-bottom: 100rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 */
.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 16rpx;
  margin-bottom: 20rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.nav-coins {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.coins-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.coins-num {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

/* Tab切换 */
.shop-tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 12rpx;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-name {
  font-size: 24rpx;
  color: #666;
}

.tab-item.active .tab-name {
  color: #fff;
  font-weight: 600;
}

/* 商品滚动区域 */
.shop-scroll {
  flex: 1;
  overflow: hidden;
}

.shop-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 10rpx;
}

.shop-item {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
}

.shop-item.owned {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

.shop-item.locked {
  opacity: 0.5;
}

.item-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%);
}

.item-preview.ring-orange {
  background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
}

.item-preview.ring-green {
  background: linear-gradient(135deg, #4CAF50 0%, #388E3C 100%);
}

.item-preview.ring-purple {
  background: linear-gradient(135deg, #9C27B0 0%, #7B1FA2 100%);
}

.item-preview.ring-pink {
  background: linear-gradient(135deg, #E91E63 0%, #C2185B 100%);
}

.item-preview.ring-black {
  background: linear-gradient(135deg, #424242 0%, #212121 100%);
}

.item-preview.ring-rainbow {
  background: linear-gradient(135deg, #FF6B6B 0%, #FFD93D 25%, #6BCB77 50%, #4D96FF 75%, #9B59B6 100%);
}

.preview-icon {
  font-size: 48rpx;
}

.item-info {
  text-align: center;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.item-price {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.price-icon {
  font-size: 20rpx;
}

.price-num {
  font-size: 26rpx;
  font-weight: 600;
  color: #FF9800;
}

.item-free {
  font-size: 24rpx;
  color: #52c41a;
}

.item-duration {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.item-status {
  font-size: 24rpx;
  color: #00B0FF;
  padding: 8rpx 24rpx;
  background: rgba(0, 176, 255, 0.1);
  border-radius: 20rpx;
}

.shop-item.owned .item-status {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.shop-item.locked .item-status {
  background: rgba(0, 0, 0, 0.05);
  color: #999;
}

/* 购买弹窗 */
.buy-popup {
  padding: 40rpx 30rpx calc(60rpx + env(safe-area-inset-bottom));
}

.buy-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.buy-item {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.buy-icon {
  font-size: 48rpx;
}

.buy-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.buy-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.buy-actions {
  display: flex;
  gap: 20rpx;
}

.buy-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.buy-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.buy-btn.confirm {
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%);
  color: #fff;
}
