.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #F0F8FF;
}

.avatar-container {
  margin-right: 20rpx;
}

.friend-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #eee;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.invite-btn {
  margin-top: 60rpx;
  padding: 0 40rpx;
}
