/* pages/discovery/discovery.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F0F8FF;
  /* 顶部安全距离：80rpx（与首页一致） */
  padding-top: 80rpx;
}

.header-section {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.chat-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 16px 0;
}

.chat-list {
  padding: 0 16px;
  display: flex;
  flex-direction: column;
}

.chat-item {
  display: flex;
  margin-bottom: 20px;
  align-items: flex-start;
}

.chat-item.left {
  flex-direction: row;
}

.chat-item.right {
  flex-direction: row-reverse;
}

.avatar-container {
  flex-shrink: 0;
  margin: 0 10px;
}

.avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: bold;
  color: #fff;
}

.ai-avatar {
  background-color: #00B0FF;
}

.user-avatar {
  background-color: #07c160;
}

.bubble {
  max-width: 70%;
  padding: 12px 16px;
  border-radius: 12px;
  font-size: 15px;
  line-height: 1.6;
  position: relative;
  word-wrap: break-word;
}

.chat-item.left .bubble {
  background-color: #ffffff;
  color: #333333;
  border-top-left-radius: 2px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.chat-item.right .bubble {
  background-color: #00B0FF;
  color: #ffffff;
  border-top-right-radius: 2px;
}

.input-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(50px + env(safe-area-inset-bottom));
  z-index: 200;
  padding: 12px 16px;
  background-color: #ffffff;
  border-top: 1rpx solid #ebedf0;
  display: flex;
  align-items: center;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.input-box {
  flex: 1;
  height: 44px;
  background-color: #f7f8fa;
  border: 1rpx solid #ebedf0;
  border-radius: 22px;
  padding: 0 20px;
  font-size: 15px;
  color: #333;
  transition: all 0.2s;
}

.send-btn {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background-color: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 10px;
  transition: all 0.2s;
}

.send-btn.active {
  background-color: #00B0FF;
  box-shadow: 0 2px 6px rgba(0, 176, 255, 0.3);
}

/* Markdown Styles Adaptation */
.md-h1, .md-h2, .md-h3 {
  font-weight: bold;
  margin: 8px 0;
}
.md-h1 { font-size: 18px; }
.md-h2 { font-size: 16px; }
.md-h3 { font-size: 15px; }
.md-p { margin-bottom: 8px; }
.md-li-bullet { display: inline-block; margin-right: 4px; }
.md-strong { font-weight: bold; }
