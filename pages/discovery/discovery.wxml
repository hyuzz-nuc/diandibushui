<view class="container" style="padding-top: calc(20rpx + env(safe-area-inset-top));">
  <!-- 顶部场景选择 -->
  <view class="header-section">
    <van-dropdown-menu active-color="#00B0FF">
      <van-dropdown-item value="{{ currentScene }}" options="{{ sceneOptions }}" bind:change="onSceneChange" />
      <van-dropdown-item value="{{ currentStyle }}" options="{{ styleOptions }}" bind:change="onStyleChange" />
    </van-dropdown-menu>
  </view>

  <!-- 聊天记录区域 -->
  <scroll-view 
    class="chat-scroll" 
    scroll-y 
    scroll-into-view="{{ scrollIntoView }}"
    scroll-with-animation
    enable-flex
  >
    <view class="chat-list">
      <!-- 欢迎语 -->
      <view class="chat-item left" wx:if="{{ chatList.length === 0 }}">
        <view class="avatar-container">
          <view class="avatar ai-avatar">AI</view>
        </view>
        <view class="bubble">
          <view class="content">你好！我是你的专属养生专家。你可以问我关于体质调理、慢病康养、四季养生或职场健康的问题。</view>
        </view>
      </view>

      <block wx:for="{{ chatList }}" wx:key="id">
        <view class="chat-item {{ item.role === 'user' ? 'right' : 'left' }}" id="msg-{{ index }}">
          <!-- 头像 -->
          <view class="avatar-container" wx:if="{{ item.role !== 'user' }}">
            <view class="avatar ai-avatar">AI</view>
          </view>
          
          <!-- 气泡 -->
          <view class="bubble {{ item.role }}">
            <view class="content">
              <rich-text nodes="{{ item.html }}" wx:if="{{ item.role === 'ai' }}"></rich-text>
              <text wx:else>{{ item.content }}</text>
            </view>
          </view>

          <!-- 用户头像 -->
          <view class="avatar-container" wx:if="{{ item.role === 'user' }}">
             <view class="avatar user-avatar">我</view>
          </view>
        </view>
      </block>

      <!-- Loading 状态 -->
      <view class="chat-item left" wx:if="{{ loading }}">
        <view class="avatar-container">
          <view class="avatar ai-avatar">AI</view>
        </view>
        <view class="bubble">
          <van-loading type="spinner" size="24px" color="#00B0FF" />
        </view>
      </view>
      
      <!-- 底部占位，防止内容被输入框遮挡 -->
      <view style="height: 300rpx;" id="bottom-anchor"></view>
    </view>
  </scroll-view>

  <!-- 底部输入区 -->
  <view class="input-area">
    <input 
      class="input-box" 
      value="{{ inputValue }}" 
      bindinput="onInput" 
      bindconfirm="onSend" 
      confirm-type="send"
      placeholder="请输入你的健康问题..." 
    />
    <view class="send-btn {{ inputValue ? 'active' : '' }}" bindtap="onSend">
      <van-icon name="guide-o" size="24px" color="{{ inputValue ? '#ffffff' : '#999999' }}" />
    </view>
  </view>
</view>