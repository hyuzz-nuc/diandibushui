.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E3F2FD 0%, #F5F5F5 30%);
  padding: 20rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* 设置卡片 */
.settings-card {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 176, 255, 0.1);
}

.card-header {
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

/* 设置行 */
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.setting-info {
  flex: 1;
}

.setting-label {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.setting-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.setting-switch-wrapper {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.permission-warning {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.warning-text {
  font-size: 22rpx;
  color: #FF6B6B;
  margin-left: 4rpx;
}

/* 时间段设置 */
.time-section {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.time-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.time-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.time-picker {
  display: flex;
  align-items: center;
  background: #F5F9FC;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
}

.time-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #00B0FF;
  margin-right: 8rpx;
}

.time-separator {
  font-size: 28rpx;
  color: #999;
  margin: 0 24rpx;
}

/* 间隔设置 */
.interval-section {
  padding: 24rpx 0;
}

.interval-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.interval-btns {
  display: flex;
  gap: 16rpx;
}

.interval-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: #F5F5F5;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.interval-btn.active {
  background: linear-gradient(135deg, #4FC3F7 0%, #00B0FF 100%);
  color: #fff;
  font-weight: 500;
}

/* 下次提醒 */
.next-reminder {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.next-reminder-text {
  font-size: 26rpx;
  color: #00B0FF;
  margin-left: 8rpx;
}

/* 提醒记录列表 */
.reminder-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.list-header {
  margin-bottom: 16rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

/* 分组 */
.reminder-group {
  margin-bottom: 24rpx;
}

.group-title {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

/* 提醒项 */
.reminder-item {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

.reminder-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.reminder-icon.system {
  background: rgba(0, 176, 255, 0.1);
}

.reminder-icon.friend {
  background: rgba(76, 175, 80, 0.1);
}

.friend-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.reminder-content {
  flex: 1;
}

.reminder-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.reminder-text {
  font-size: 28rpx;
  color: #333;
}

/* 空状态 */
.empty-state {
  padding: 60rpx 0;
}

/* 时间选择器弹窗 */
.time-picker-popup {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.picker-cancel {
  font-size: 28rpx;
  color: #999;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.picker-confirm {
  font-size: 28rpx;
  color: #00B0FF;
  font-weight: 500;
}

.picker-view {
  height: 400rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #333;
}
